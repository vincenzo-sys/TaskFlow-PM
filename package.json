{
  "name": "taskflow",
  "version": "1.0.0",
  "private": true,
  "description": "TaskFlow PM - AI-powered task management",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "dev:web": "npm run dev --workspace=apps/web",
    "dev:electron": "npm run start --workspace=apps/electron",
    "dev:mcp": "npm run dev --workspace=apps/mcp-server",
    "build:web": "npm run build --workspace=apps/web",
    "build:shared": "npm run build --workspace=packages/shared"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.3.0"
  },
  "packageManager": "npm@10.2.0"
}
